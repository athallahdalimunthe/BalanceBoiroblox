-- ╔══════════════════════════════════════════╗
-- ║   JUMP UPDATE HANDLER                    ║
-- ╚══════════════════════════════════════════╝

JumpUpdate.Event:Connect(function(normalLeft, normalMax, casualLeft, casualMax, jumpType)
	local activeLeft = jumpType == "CasualWing" and casualLeft or normalLeft
	local activeMax  = jumpType == "CasualWing" and casualMax  or normalMax

	-- Rebuild panel if count changed OR type switched
	if activeMax ~= lastMax or jumpType ~= lastType then
		buildPanel(activeMax, jumpType)
		lastMax  = activeMax
		lastType = jumpType
	end

	updatePips(activeLeft, activeMax, jumpType)

	-- Edge glow when out of jumps
	local typeConf = CONFIG[jumpType] or CONFIG.Normal
	if activeLeft == 0 then
		flashEdge(typeConf.GlowColor, 0.5)
	end
end)

