local EdgeGlow = Instance.new("Frame")
EdgeGlow.Size  = UDim2.new(1,0,1,0)
EdgeGlow.BackgroundTransparency = 1
EdgeGlow.BorderSizePixel = 0
EdgeGlow.ZIndex = 10
EdgeGlow.Parent = ScreenGui

local glowImg = Instance.new("ImageLabel")
glowImg.Size  = UDim2.new(1,0,1,0)
glowImg.BackgroundTransparency = 1
glowImg.Image = "rbxasset://textures/ui/VignetteBlur.png"
glowImg.ImageColor3 = CONFIG.MaxJumpGlowColor
glowImg.ImageTransparency = 1
glowImg.Parent = EdgeGlow

local function flashEdge(color, duration)
	glowImg.ImageColor3 = color
	TweenService:Create(glowImg,
		TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ ImageTransparency = 0.3 }
	):Play()
	task.delay(duration or 0.4, function()
		TweenService:Create(glowImg,
			TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{ ImageTransparency = 1 }
		):Play()
	end)
end

