-- ╔══════════════════════════════════════════╗
-- ║   HELPERS                                ║
-- ╚══════════════════════════════════════════╝

local function makeFrame(name, parent, size, pos, bg, alpha, radius)
	local f = Instance.new("Frame")
	f.Name = name; f.Size = size; f.Position = pos
	f.BackgroundColor3 = bg or Color3.fromRGB(20,20,30)
	f.BackgroundTransparency = alpha or 0.4
	f.BorderSizePixel = 0; f.Parent = parent
	Instance.new("UICorner", f).CornerRadius = UDim.new(0, radius or 12)
	return f
end

local function makeImage(name, parent, size, pos, id)
	local img = Instance.new("ImageLabel")
	img.Name = name; img.Size = size; img.Position = pos
	img.BackgroundTransparency = 1
	img.Image = id; img.ScaleType = Enum.ScaleType.Fit
	img.Parent = parent
	return img
end

local function addStroke(p, thick, col, trans)
	local s = Instance.new("UIStroke")
	s.Thickness = thick or 2; s.Color = col or Color3.new(1,1,1)
	s.Transparency = trans or 0.6
	s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	s.Parent = p
end

local function getColor(index)
	local c = CONFIG.JumpColors
	return c[((index-1) % #c) + 1]
end

-- ╔══════════════════════════════════════════╗
-- ║   1.  JUMP PIP PANEL  (top-center)       ║
-- ║   Fully rebuilt on respawn — no stale UI ║
-- ╚══════════════════════════════════════════╝

local pipSize  = 26
local pipGap   = 5
local panelH   = 48

local JumpPanel      = nil
local jumpCountLabel = nil
local pips           = {}
local lastMax        = -1

local function buildJumpPanel(maxJumps)
	-- Destroy old panel completely
	if JumpPanel and JumpPanel.Parent then
		JumpPanel:Destroy()
	end
	pips    = {}
	lastMax = maxJumps

	local displayCount = math.min(maxJumps, 10)
	local newW = displayCount * (pipSize + pipGap) + 16

	JumpPanel = makeFrame(
		"JumpPanel", ScreenGui,
		UDim2.new(0, newW, 0, panelH),
		UDim2.new(0.5, -newW/2, 0, 82),
		Color3.fromRGB(10, 10, 22), 0.45, 12
	)
	addStroke(JumpPanel, 1.5, Color3.fromRGB(180, 180, 255), 0.55)

	local pipLayout = Instance.new("UIListLayout")
	pipLayout.FillDirection       = Enum.FillDirection.Horizontal
	pipLayout.Padding             = UDim.new(0, pipGap)
	pipLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
	pipLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	pipLayout.Parent              = JumpPanel

	local pipPadding        = Instance.new("UIPadding")
	pipPadding.PaddingLeft  = UDim.new(0, 8)
	pipPadding.PaddingRight = UDim.new(0, 8)
	pipPadding.Parent       = JumpPanel

	jumpCountLabel                      = Instance.new("TextLabel")
	jumpCountLabel.Name                 = "JumpCount"
	jumpCountLabel.Size                 = UDim2.new(0, 50, 1, 0)
	jumpCountLabel.Position             = UDim2.new(1, 4, 0, 0)
	jumpCountLabel.BackgroundTransparency = 1
	jumpCountLabel.TextColor3           = Color3.fromRGB(220, 220, 255)
	jumpCountLabel.TextScaled           = true
	jumpCountLabel.Font                 = Enum.Font.GothamBold
	jumpCountLabel.Text                 = maxJumps > 10 and ("x"..maxJumps) or ""
	jumpCountLabel.Parent               = JumpPanel

	for i = 1, displayCount do
		local pip = makeImage(
			"Pip_"..i, JumpPanel,
			UDim2.new(0, pipSize, 0, pipSize),
			UDim2.new(0,0,0,0),
			CONFIG.JumpPipFull
		)
		pip.ImageColor3 = getColor(i)
		pips[i] = pip
	end
end

-- Lightweight update — only rebuilds if count changed, otherwise just recolors
local function rebuildPips(maxJumps)
	if maxJumps ~= lastMax or not JumpPanel or not JumpPanel.Parent then
		buildJumpPanel(maxJumps)
	end
end

