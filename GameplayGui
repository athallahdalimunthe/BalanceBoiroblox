end)

-- ╔══════════════════════════════════════════╗
-- ║   4.  JUMP UPDATE HANDLER                ║
-- ╚══════════════════════════════════════════╝

local lastKnownMax = CONFIG.MinJumps

local function onJumpUpdate(jumpsLeft, maxJumps)
	-- Detect steal vs loss for glow color
	if maxJumps > lastKnownMax then
		flashEdge(CONFIG.StealGlowColor, 0.3)   -- green: you gained a jump
	elseif maxJumps < lastKnownMax then
		flashEdge(CONFIG.LostGlowColor, 0.5)    -- red: you lost a jump
	elseif jumpsLeft == 0 then
		flashEdge(CONFIG.MaxJumpGlowColor, 0.5) -- pink: out of jumps
	end
	lastKnownMax = maxJumps

	-- Rebuild pips if count changed
	rebuildPips(maxJumps)

	-- Update pip states
	local displayCount = math.min(maxJumps, 10)
	for i = 1, displayCount do
		local pip = pips[i]
		if not pip then continue end

		if i <= jumpsLeft then
			pip.Image = CONFIG.JumpPipFull
			pip.ImageColor3 = getColor(i)
			TweenService:Create(pip,
				TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
				{ ImageTransparency = 0, Size = UDim2.new(0, pipSize, 0, pipSize) }
			):Play()
		else
			pip.Image = CONFIG.JumpPipEmpty
			TweenService:Create(pip,
				TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{ ImageTransparency = 0.6, Size = UDim2.new(0, pipSize-6, 0, pipSize-6) }
			):Play()
		end
	end

	-- Panel bounce
	if not JumpPanel or not JumpPanel.Parent then return end
	local w = JumpPanel.Size.X.Offset
	TweenService:Create(JumpPanel,
		TweenInfo.new(0.08, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{ Size = UDim2.new(0, w+10, 0, panelH+6),
			Position = UDim2.new(0.5, -(w+10)/2, 0, 79) }
	):Play()
	task.delay(0.12, function()
		TweenService:Create(JumpPanel,
			TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Size = UDim2.new(0, w, 0, panelH),
				Position = UDim2.new(0.5, -w/2, 0, 82) }
		):Play()
	end)
end

JumpUpdate.Event:Connect(onJumpUpdate)

