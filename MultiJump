local CONFIG = {
	MinJumps       = 5,
	JumpPower      = 55,
	ExtraJumpPower = 50,
	JumpSoundId    = "rbxassetid://138963217663286",
	RingImageId    = "rbxassetid://73061577156450",
	HitRange       = 20,   -- must match JumpManager HitRange
	PunchCooldown  = 0.5,
	CameraShakeAmount = 0.18,

	JumpColors = {
		Color3.fromRGB(255, 255, 255),
		Color3.fromRGB(100, 220, 255),
		Color3.fromRGB(120, 255, 120),
		Color3.fromRGB(255, 200,  60),
		Color3.fromRGB(255,  80, 200),
		Color3.fromRGB(255, 120,  60),
		Color3.fromRGB(200,  80, 255),
		Color3.fromRGB(255, 255,  60),
	},
}

