-- ║   CHARACTER REFS                         ║
-- ╚══════════════════════════════════════════╝

local Character    = script.Parent
local Humanoid     = Character:WaitForChild("Humanoid")
local HRP          = Character:WaitForChild("HumanoidRootPart")

local maxJumps      = CONFIG.MinJumps
local jumpsLeft     = maxJumps
local isGrounded    = true
local jumpCooldown  = false
local punchCooldown = false
local isShielded    = false   -- toggled by ShieldStateChanged

-- ╔══════════════════════════════════════════╗
-- ║   CLEANUP FROM PREVIOUS LIFE             ║
-- ╚══════════════════════════════════════════╝

local oldFlash = PlayerGui:FindFirstChild("JumpFlash")
if oldFlash then oldFlash:Destroy() end
local oldBF = PlayerGui:FindFirstChild("RequestJump")
